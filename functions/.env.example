# functions/.env.example
# Copia este archivo a functions/.env y rellena con tus valores REALES.
# El archivo functions/.env está en .gitignore — NUNCA subir a git.

# URL pública de tu app en Firebase Hosting
# Ejemplo: https://planea-pro-xxxxx.web.app
APP_URL=https://TU_PROYECTO.web.app

# URL pública de la Cloud Function webhookMercadoPago (obtener tras primer despliegue)
# Ejemplo: https://us-central1-TU_PROYECTO_ID.cloudfunctions.net/webhookMercadoPago
WEBHOOK_URL=https://us-central1-TU_PROYECTO_ID.cloudfunctions.net/webhookMercadoPago
