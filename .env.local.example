# PLANEA-PRO — Copia este archivo a .env.local y rellena los valores.
# .env.local NUNCA debe subirse al repositorio (está en .gitignore).

# ─── Gemini (proveedor activo) ────────────────────────────────
# Obtener en Google Cloud Console → APIs & Services → Credentials
# O en https://aistudio.google.com → "Get API key"
VITE_GEMINI_API_KEY=tu-gemini-api-key-aqui
VITE_GEMINI_MODEL=gemini-2.5-flash

# ─── Anthropic (alternativa, comentado por defecto) ──────────
# VITE_ANTHROPIC_API_KEY=
# VITE_ANTHROPIC_MODEL=claude-opus-4-7
